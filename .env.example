# Database (local PostgreSQL via docker-compose.yml)
DATABASE_URL="postgresql://paperclip:paperclip@127.0.0.1:55432/paperclip"
DIRECT_URL="postgresql://paperclip:paperclip@127.0.0.1:55432/paperclip"

# Single-user access
OWNER_EMAIL="owner@example.com"

# Local scheduler / API trigger guard
CRON_SECRET="replace-with-random-secret"

# AI adapter
AI_ADAPTER="mock"
AI_ADAPTER_ALLOW_MOCK="true"
OPENAI_API_KEY=""
CLAUDE_API_KEY=""
COST_LOG_ENABLED="true"
DAILY_AI_COST_CAP_USD="5"

# Naver APIs
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
NAVER_BLOG_SEARCH_URL="https://openapi.naver.com/v1/search/blog.json"
NAVER_SHOPPING_SEARCH_URL="https://openapi.naver.com/v1/search/shop.json"

# Local file storage
LOCAL_STORAGE_DIR="./storage"

# Logging
ERROR_LOG_ENABLED="true"
