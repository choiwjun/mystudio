    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "seed": "tsx prisma/seed.ts",
    "audit:prod": "npm audit --omit=dev"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "dompurify": "latest",
    "jose": "^6.2.3",
    "ky": "latest",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "pino": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@playwright/test": "^1.61.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "jsdom": "latest",
    "prisma": "6.19.3",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "@prisma/client@6.19.3": true,
    "prisma@6.19.3": true,
    "@prisma/engines@6.19.3": true
  }
