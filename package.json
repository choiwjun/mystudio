{
  "name": "paperclip-company-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "lint": "biome check app lib scripts tests prisma components next.config.mjs vitest.config.ts playwright.config.ts proxy.ts tsconfig.json package.json",
    "format": "biome check --write app lib scripts tests prisma components next.config.mjs vitest.config.ts playwright.config.ts proxy.ts tsconfig.json package.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "next build && playwright test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "seed": "tsx prisma/seed.ts",
    "scan:hermes": "tsx scripts/hermes-scan.ts",
    "audit:prod": "npm audit --omit=dev"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "jose": "6.2.3",
    "ky": "1.14.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jsdom": "29.1.1",
    "prisma": "6.19.3",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "@prisma/client@6.19.3": true,
    "prisma@6.19.3": true,
    "@prisma/engines@6.19.3": true
  }
}
